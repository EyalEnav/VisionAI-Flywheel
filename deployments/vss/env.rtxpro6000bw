# Environment profile for 2× NVIDIA RTX PRO 6000 Blackwell
# Source this before starting the VSS stack:
#   set -a; source deployments/vss/env.rtxpro6000bw; set +a

export HARDWARE_PROFILE=rtx6000blackwell
export BP_PROFILE=bp_developer_base_2d

# GPU assignments
export VSS_GPU_DEVICE=0
export TRANSFER_GPU_DEVICE=1
export SHARED_LLM_VLM_DEVICE_ID=0
export VLM_DEVICE_ID=0

# NIM ports
export VLM_PORT=30082
export LLM_PORT=30081

# VSS ports
export VSS_AGENT_PORT=8000
export SENSOR_HTTP_PORT=30000

# MDX paths
export MDX_SAMPLE_APPS_DIR=/home/ubuntu/video-search-and-summarization/deployments
export VST_CONFIG_PATH=${MDX_SAMPLE_APPS_DIR}/vst/developer/vst/configs
export VST_DATA_PATH=/tmp/vst_data
export VST_VIDEO_STORAGE_PATH=/tmp/vst_video

# NIM memory — shared GPU, 40% each
export VLM_NIM_KVCACHE_PERCENT=40

# Postgres
export CENTRALIZE_DB_NAME=mdxdb
export CENTRALIZE_DB_USERNAME=mdxuser
