# ─── NVIDIA ───────────────────────────────────────────────────────────────────
NGC_CLI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Hardware profile (for VSS NIM selection) ─────────────────────────────────
# Options: rtx6000blackwell | H100 | L40S | OTHER
HARDWARE_PROFILE=rtx6000blackwell

# ─── GPU assignment ───────────────────────────────────────────────────────────
VSS_GPU_DEVICE=0          # VSS + Kimodo + Render API
TRANSFER_GPU_DEVICE=1     # Cosmos Transfer2.5

# ─── VSS ports ────────────────────────────────────────────────────────────────
VST_PORT=77770
VSS_AGENT_PORT=8000
VLM_PORT=30082            # Cosmos-Reason2-8B NIM
LLM_PORT=30081            # Nemotron-Nano-9B NIM
KIMODO_TEXT_ENCODER_PORT=9550
RENDER_API_PORT=9000

# ─── Paths ────────────────────────────────────────────────────────────────────
HF_CACHE=/ephemeral/cache/huggingface
KIMODO_OUTPUT_DIR=/home/ubuntu/kimodo_output
RENDER_OUTPUT_DIR=/tmp/render_output

# ─── VSS Blueprint profile ────────────────────────────────────────────────────
BP_PROFILE=bp_developer_base_2d
